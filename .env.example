# LLM provider: "openai", "ollama", or "iaedu"
LLM_PROVIDER=iaedu

# --- IAEDU agent-chat — when LLM_PROVIDER=iaedu ---
IAEDU_API_KEY=sk-usr-...
IAEDU_CHANNEL_ID=cmpyxvcx42ltml1012mfhvkkp
IAEDU_ENDPOINT=https://api.iaedu.pt/agent-chat/api/v1/agent/cmor5objoex9gfp01vm7p95jh/stream

# --- OpenAI (GPT) — when LLM_PROVIDER=openai ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Ollama (local) — when LLM_PROVIDER=ollama ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# NLP pipeline (BERT + LDA)
BERT_MODEL=nlptown/bert-base-multilingual-uncased-sentiment
LDA_NUM_TOPICS=8
NLP_BATCH_SIZE=32

# Scraping defaults
DEFAULT_APP_ID=com.whatsapp
SCRAPE_LANG=pt
SCRAPE_COUNTRY=pt
